# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.

FLASK_ENV=development

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY
JWT_SECRET_KEY=CHANGE_THIS_TO_A_DIFFERENT_RANDOM_KEY

# SQLite (development default)
DEV_DATABASE_URL=sqlite:///fakenews_dev.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/fakenews
